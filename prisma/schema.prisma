// prisma/schema.prisma
datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

enum Role {
  USER
  ADMIN
  SUPERVISOR
}

enum TwoFactorMethod {
  NONE
  AUTHENTICATOR
  EMAIL_OTP
}

model User {
  id                Int              @id @default(autoincrement())
  uuid              String           @unique @default(uuid())
  email             String           @unique
  password          String
  firstname         String
  lastname          String
  role              Role             @default(USER)
  
  twoFactorMethod   TwoFactorMethod  @default(NONE)
  twoFactorSecret   String?
  twoFactorEnabled  Boolean          @default(false)
  
  recentOnline      DateTime         @updatedAt
  createdAt         DateTime         @default(now())
  
  recoveryKeys      RecoveryKey[]
  sessions          Session[]
  passwordHistory   PasswordHistory[]
  auditLogs         AuditLog[]
  failedAttempts    FailedLoginAttempt[]

  status        String   @default("Active")
}

model RecoveryKey {
  id        String   @id @default(uuid())
  userId    Int
  keyHash   String
  usedAt    DateTime?
  createdAt DateTime @default(now())
  expiresAt DateTime
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id           String   @id @default(uuid())
  userId       Int
  tokenHash    String   @unique
  ipAddress    String
  userAgent    String
  lastActiveAt DateTime @default(now())
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordHistory {
  id           String   @id @default(uuid())
  userId       Int
  passwordHash String
  createdAt    DateTime @default(now())
  
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FailedLoginAttempt {
  id           String   @id @default(uuid())
  email        String
  ipAddress    String
  attempts     Int      @default(1)
  lastAttempt  DateTime @default(now())
  lockedUntil  DateTime?
  
  // Add opposite relation field to fix the error
  user         User?    @relation(fields: [userId], references: [id])
  userId       Int?
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    Int?
  action    String
  ipAddress String
  userAgent String
  details   String?
  createdAt DateTime @default(now())
  
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model JwtBlacklist {
  id        String   @id @default(uuid())
  token     String   @unique
  createdAt DateTime @default(now())
}

enum NewsType {
  NEWS
  PR
}

enum GalleryType {
  IMAGE
  VIDEO
}

model News {
  id          Int      @id @default(autoincrement())
  type        NewsType 
  title       String
  date        DateTime @default(now())
  image_src   String
  description String
  content     String?  @db.Text
  views       Int      @default(0)
  isShow      Boolean  @default(true)
}

model Department {
  id          Int           @id @default(autoincrement())
  title       String
  cover_image String
  content     String?       @db.Text
  isDelete    Boolean       @default(false)
  gallery     GalleryItem[]
}

model GalleryItem {
  id           Int        @id @default(autoincrement())
  type         GalleryType
  url          String
  departmentId Int
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
}

model ContactRequest {
  id               String   @id @default(cuid())
  firstName        String   @map("first_name") 
  lastName         String   @map("last_name")
  email            String
  telNumber        String   @map("tel_number")
  preferredContact String   @map("preferred_contact")
  message          String   @db.Text
  status           String   @default("ยังไม่ตอบกลับ")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("contact_requests")
}

model CommentItem {
  id        String   @id @default(uuid())
  star      Int
  msg       String   @db.Text
  isShow    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("comment_items")
}

model SliderImage {
  id        Int      @id @default(autoincrement())
  image_url String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@map("slider_images")
}